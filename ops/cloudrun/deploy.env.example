# Target project for THIS new social agent (must be separate from any existing bot deployment).
PROJECT_ID=your-new-gcp-project-id
CONFIRM_PROJECT_ID=your-new-gcp-project-id
REGION=us-central1

# Use a dedicated Cloud Run service name to avoid confusion with existing services.
SERVICE_NAME=social-agent-autonomo
SERVICE_ACCOUNT_NAME=social-agent-sa

# Artifact Registry / image config
ARTIFACT_REPO=social-agent
IMAGE_NAME=social-agent
IMAGE_TAG=staging

# App runtime config
ENVIRONMENT=staging
GCP_LOCATION=global
DATABASE_URL=sqlite+aiosqlite:////tmp/social_agent.db
REDDIT_USER_AGENT=ByteSocialAgent/1.0.0

# Cloud Run sizing
CPU=1
MEMORY=512Mi
MIN_INSTANCES=0
MAX_INSTANCES=3
TIMEOUT_SECONDS=300

# Safety switch: keep 0 by default to prevent accidental updates of an existing service.
ALLOW_UPDATE_EXISTING_SERVICE=0
