# Target project for THIS new social agent (must be separate from any existing bot deployment).
PROJECT_ID=your-new-gcp-project-id
CONFIRM_PROJECT_ID=your-new-gcp-project-id
REGION=us-central1

# Use a dedicated Cloud Run service name to avoid confusion with existing services.
SERVICE_NAME=social-agent-autonomo
SERVICE_ACCOUNT_NAME=social-agent-sa

# Artifact Registry / image config
ARTIFACT_REPO=social-agent
IMAGE_NAME=social-agent
IMAGE_TAG=staging

# App runtime config
ENVIRONMENT=staging
GCP_LOCATION=global
DATABASE_URL=sqlite+aiosqlite:////tmp/social_agent.db
REDDIT_USER_AGENT=ByteSocialAgent/1.0.0
AUTONOMY_POLL_SECONDS=5
AUTONOMY_ENABLE_PROACTIVE=1
AUTONOMY_USE_LLM_GENERATION=1
AUTONOMY_MAX_PROACTIVE_ACTIONS_PER_TICK=1
AUTONOMY_ENABLE_GROUNDING=1
AUTONOMY_REQUIRE_GROUNDING=1
AUTONOMY_DEFAULT_LANGUAGE=pt
AGENT_GOAL="Construir audiencia de alta lealdade e crescer alcance com conteudo de alta conviccao."
AGENT_IDEOLOGY="Lideranca forte, responsabilidade individual, liberdade economica, disciplina e resultado."
AGENT_MORAL_FRAMEWORK="Sem coercao, sem assedio, sem desinformacao, sem manipulacao predatoria."
AGENT_DOMINANT_MODE=1
AGENT_PRIMARY_CTA="Siga e ative notificacoes para acompanhar os proximos movimentos."
AGENT_GROWTH_KPI_PRIORITIES=reach,share_rate,follow_conversion,retention
INSTAGRAM_DEFAULT_IMAGE_URL=
X_EXECUTION_MODE=operator
OPERATOR_FALLBACK_ON_API_ERROR=1

# Cloud Run sizing
CPU=1
MEMORY=512Mi
MIN_INSTANCES=0
MAX_INSTANCES=3
TIMEOUT_SECONDS=300

# Safety switch: keep 0 by default to prevent accidental updates of an existing service.
ALLOW_UPDATE_EXISTING_SERVICE=0
